{
  "manifest_version": 3,
  "name": "0flufStart",
  "short_name": "0Fluff",
  "version": "1.3.2",
  "description": "Zero-Fluff. All Speed. A privacy-first, minimalist start page.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "start_url": "./index.html",
  "display": "standalone",
  "background_color": "#000000",
  "theme_color": "#000000",
  "icons": [
    {
      "src": "icon512.png",
      "sizes": "128x128",
      "type": "image/png"
    },
    {
      "src": "icon512.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icon512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ]
}
