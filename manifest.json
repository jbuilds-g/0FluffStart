{
  "manifest_version": 3,
  "name": "0flufStart",
  "short_name": "0Fluff",
  "version": "1.3.2",
  "description": "Zero-Fluff. All Speed. A privacy-first, minimalist start page.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "display": "standalone",
  "start_url": "./index.html",
  "background_color": "#000000",
  "theme_color": "#000000"
}
