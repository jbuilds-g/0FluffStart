{
  "manifest_version": 3,
  "name": "0flufStart",
  "version": "1.9.1",
  "description": "Zero-Fluff. All Speed. A privacy-first, minimalist start page.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": ["storage", "unlimitedStorage"],
  "start_url": "./index.html",
  "display": "standalone",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png",
    "192": "icon.png",
    "512": "icon.png"
  }
}
